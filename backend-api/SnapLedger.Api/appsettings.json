{
  "ConnectionStrings": {
    "DefaultConnection": "Host=DATABASE_HOST;Database=DATABASE_NAME;Username=DATABASE_USER;Password=DATABASE_PASSWORD;SSL Mode=Require;Trust Server Certificate=true;"
  },
  "Jwt": {
    "Secret": "YOUR_SUPER_SECRET_JWT_KEY_MIN_32_CHARS_LONG",
    "Issuer": "snapledger-api",
    "Audience": "snapledger-clients"
  },
  "Google": {
    "ClientId": "YOUR_GOOGLE_OAUTH_CLIENT_ID"
  },
  "OcrSpace": {
    "ApiKey": "YOUR_OCR_SPACE_API_KEY"
  },
  "ImgBB": {
    "ApiKey": "YOUR_IMGBB_API_KEY"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
